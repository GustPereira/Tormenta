# Compartilhamento de fichas (opcional). Sem isso, os recursos de compartilhar
# ficam desabilitados, mas o app funciona normalmente (100% local).
#
# Repositório de dados PÚBLICO e SEPARADO (não o repo do app).
VITE_SHARE_REPO=GustPereira/tormenta-shared
#
# Fine-grained PAT com acesso SÓ ao repo acima e permissão Contents: Read and write.
# Atenção: num app estático este token vai para o bundle público — use um repo
# dedicado para limitar o alcance.
VITE_SHARE_TOKEN=github_pat_xxx
